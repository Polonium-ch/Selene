      <sparkle:version>4</sparkle:version>
      <sparkle:shortVersionString>0.1.3</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
      <description><![CDATA[
<h2>New</h2>
<ul>
<li>Gamepad support - buttons, sticks, and analog triggers for any controller macOS pairs natively (DualSense, DualShock 4, Xbox, and other GameController-recognized pads)</li>
</ul>
<h2>Changed</h2>
<ul>
<li>Install script now points at install.getselene.ch</li>
</ul>
      ]]></description>
